[
  {
    "key": "font.family",
    "category": "Font",
    "type": "string",
    "default": null,
    "description": "Renderer に渡すフォントファミリー名。未指定時はレンダラーの既定フォントを使います。",
    "examples": [
      "[font]\nfamily = \"CaskaydiaCove Nerd Font\"\n"
    ],
    "reload": "restart",
    "platform": "all",
    "since": "0.1.0"
  },
  {
    "key": "font.line_height",
    "category": "Font",
    "type": "float",
    "default": null,
    "description": "セルの行高。未指定時はフォントサイズに合わせたレンダラー既定値を使います。",
    "examples": [
      "[font]\nline_height = 22.0\n"
    ],
    "range": "finite > 0",
    "reload": "restart",
    "platform": "all",
    "since": "0.1.0"
  },
  {
    "key": "font.size",
    "category": "Font",
    "type": "float",
    "default": 16.0,
    "description": "セルメトリクスの基準になるフォントサイズ。0 より大きい有限値を指定します。",
    "examples": [
      "[font]\nsize = 18.0\n"
    ],
    "range": "finite > 0",
    "reload": "restart",
    "platform": "all",
    "since": "0.1.0"
  },
  {
    "key": "hyperlink.allowed_schemes",
    "category": "Hyperlink",
    "type": "list<string>",
    "default": [
      "https",
      "http"
    ],
    "description": "Ctrl click で開くことを許可する URL scheme。空配列にすると hyperlink open は無効になります。",
    "examples": [
      "[hyperlink]\nallowed_schemes = [\"https\"]\n"
    ],
    "reload": "restart",
    "platform": "all",
    "security": "許可した scheme は外部アプリケーション起動につながるため、必要な scheme のみに絞ってください。",
    "since": "0.1.0"
  },
  {
    "key": "hyperlink.open_on_ctrl_click",
    "category": "Hyperlink",
    "type": "bool",
    "default": true,
    "description": "Ctrl click で OSC 8 hyperlink を開くかどうか。",
    "examples": [
      "[hyperlink]\nopen_on_ctrl_click = false\n"
    ],
    "reload": "restart",
    "platform": "all",
    "security": "有効にすると許可された scheme の URL を OS の既定ハンドラーで開きます。",
    "since": "0.1.0"
  },
  {
    "key": "hyperlink.underline_on_hover",
    "category": "Hyperlink",
    "type": "bool",
    "default": true,
    "description": "hover 中の hyperlink に underline 表示を付けるかどうか。",
    "examples": [
      "[hyperlink]\nunderline_on_hover = false\n"
    ],
    "reload": "restart",
    "platform": "all",
    "since": "0.1.0"
  },
  {
    "key": "render.wgpu_backend",
    "category": "Render",
    "type": "enum",
    "default": "auto",
    "description": "wgpu の描画バックエンド。環境変数 KNIGHTTY_WGPU_BACKEND がある場合はそちらが優先されます。",
    "examples": [
      "[render]\nwgpu_backend = \"gl\"\n"
    ],
    "validValues": [
      "auto",
      "vulkan",
      "dx12",
      "gl"
    ],
    "reload": "restart",
    "platform": "all",
    "since": "0.1.0"
  },
  {
    "key": "shell.args",
    "category": "Shell",
    "type": "list<string>",
    "default": [],
    "description": "shell program に渡す引数の配列。",
    "examples": [
      "[shell]\nprogram = \"pwsh\"\nargs = [\"-NoLogo\"]\n"
    ],
    "reload": "new-terminal",
    "platform": "all",
    "security": "shell program に渡されるため、引数には信頼できる値だけを指定してください。",
    "since": "0.1.0"
  },
  {
    "key": "shell.program",
    "category": "Shell",
    "type": "string",
    "default": null,
    "description": "起動する shell program。未指定時は platform の既定 shell を使います。",
    "examples": [
      "[shell]\nprogram = \"pwsh\"\n"
    ],
    "range": "non-empty when set",
    "reload": "new-terminal",
    "platform": "all",
    "security": "外部コマンド起動につながるため、信頼できる shell program だけを指定してください。",
    "since": "0.1.0"
  },
  {
    "key": "terminal.scroll_multiplier",
    "category": "Terminal",
    "type": "int",
    "default": 3,
    "description": "通常スクロール時に 1 wheel step あたり移動する行数。1 から 100 までの値を指定できます。",
    "examples": [
      "[terminal]\nscroll_multiplier = 5\n"
    ],
    "range": "1..=100",
    "reload": "restart",
    "platform": "all",
    "since": "0.1.0"
  },
  {
    "key": "terminal.scrollback_lines",
    "category": "Terminal",
    "type": "int",
    "default": 10000,
    "description": "保持するスクロールバック行数。0 から 100000 までの値を指定できます。",
    "examples": [
      "[terminal]\nscrollback_lines = 20000\n"
    ],
    "range": "0..=100000",
    "reload": "restart",
    "platform": "all",
    "since": "0.1.0"
  },
  {
    "key": "window.initial_cols",
    "category": "Window",
    "type": "int",
    "default": 80,
    "description": "起動時に作成する端末グリッドの列数。0 より大きい値を指定します。",
    "examples": [
      "[window]\ninitial_cols = 120\n"
    ],
    "range": "1..",
    "reload": "restart",
    "platform": "all",
    "since": "0.1.0"
  },
  {
    "key": "window.initial_rows",
    "category": "Window",
    "type": "int",
    "default": 24,
    "description": "起動時に作成する端末グリッドの行数。0 より大きい値を指定します。",
    "examples": [
      "[window]\ninitial_rows = 36\n"
    ],
    "range": "1..",
    "reload": "restart",
    "platform": "all",
    "since": "0.1.0"
  }
]
